// Two-dimensional array — nested FOR
// Run: pseudocode run examples/vanilla-pseudocode/array-2d.pseudo

DECLARE G : ARRAY[1:3, 1:4] OF INTEGER
DECLARE r : INTEGER
DECLARE c : INTEGER
FOR r <- 1 TO 3
  FOR c <- 1 TO 4
    G[r, c] <- r * 10 + c
  NEXT c
NEXT r
OUTPUT "G[2,3] = ", G[2, 3]
OUTPUT "LENGTH(G) total cells = ", LENGTH(G)
