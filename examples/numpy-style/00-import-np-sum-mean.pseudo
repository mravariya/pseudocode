// Runnable: np.sum / np.mean after IMPORT (built-in array helpers).
// Run: pseudocode run examples/numpy-style/00-import-np-sum-mean.pseudo

IMPORT numpy AS np

DECLARE A : ARRAY[1:6] OF REAL
DECLARE s : REAL
DECLARE mean : REAL

A[1] <- 2.0
A[2] <- 4.0
A[3] <- 6.0
A[4] <- 8.0
A[5] <- 10.0
A[6] <- 12.0

s <- np.sum(A)
mean <- np.mean(A)

OUTPUT "sum = ", s
OUTPUT "mean = ", mean
