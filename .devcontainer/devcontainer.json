{
  "name": "Pseudocode interpreter (C11)",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-22.04",
  "postCreateCommand": "chmod +x scripts/build.sh scripts/dev.sh 2>/dev/null || true; ./scripts/build.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode.cpptools"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "PSEUDOCODE_STDLIB": "${containerWorkspaceFolder}/stdlib-packages"
  }
}
